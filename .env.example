# Shared application database
DATABASE_URL=postgres://postgres:password@localhost/sakiot_rouvas

# Shared media storage
SAKIOT_DATA_DIR=./data

# FBI Agent: required Discord credentials
DISCORD_TOKEN_DEBUG=your_debug_bot_token
APPLICATION_ID_DEBUG=000000000000000000
DISCORD_TOKEN_RELEASE=your_release_bot_token
APPLICATION_ID_RELEASE=000000000000000000

# FBI Agent: optional runtime and deployment settings
REAPER_PURGE=false
GRPC_ADDR=[::1]:50053
BOT_INSTANCE_ID=
BOT_ROLE=active
DRAIN_TIMEOUT_SECONDS=1800
RELEASE_ID=
FBI_AGENT_GRPC_ADDR=127.0.0.1:50052
WEB_SERVER_URL=http://127.0.0.1:8900
GRPCURL_BIN=
CURL_BIN=

# Web server: required credentials
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret

# Web server: optional local and deployment settings
DEV_ACCOUNT_ID=0
DEV_LOGIN_SECRET=
COOKIE_DOMAIN=localhost
DISCORD_REDIRECT_URI=http://localhost:8900/api/discord_login
GRPC_ADDRESS=http://[::1]:50052
CORS_ALLOWED_ORIGIN=http://localhost:8081
OAUTH_ALLOWED_OPENER_ORIGINS=
OAUTH_ALLOWED_OPENER_HOST_SUFFIXES=
FBI_AGENT_REGISTRY_SECRET=
HOST=127.0.0.1
PORT=8900
DB_MAX_CONNECTIONS=20
OTEL_SERVICE_INSTANCE_ID=
SERVICE_INSTANCE_ID=

# Frontend. VITE_* values are embedded into browser bundles; never put a
# privileged server-side secret here.
VITE_API_URL=http://localhost:8900/api/
VITE_DEV_LOGIN_SECRET=

# OpenAPI type generation
OPENAPI_URL=http://localhost:8900/api-doc/openapi.json
OPENAPI_OUT=src/api/openapi.ts

# Encrypted database backups. This can differ from DATABASE_URL when backup
# tooling connects through a different host or credential.
BACKUP_DATABASE_URL=postgres://postgres:password@localhost/sakiot_rouvas
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
BACKUP_DIR=/var/lib/sakiot/backups
AGE_RECIPIENT=age1replace_with_public_key
AGE_KEY_FILE=/etc/sakiot/age-key.txt
HOURLY_RETENTION_DAYS=7
NIGHTLY_RETENTION_DAYS=90
PREMIGRATE_RETENTION_DAYS=90
HEALTHCHECK_URL=
HEALTHCHECK_URL_RESTORE=
