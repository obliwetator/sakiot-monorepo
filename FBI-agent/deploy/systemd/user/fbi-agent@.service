[Unit]
Description=FBI Agent Discord bot release %i
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
Restart=on-failure
RestartSec=1
WorkingDirectory=/home/tulipan/projects/sakiot-monorepo/FBI-agent
EnvironmentFile=/home/tulipan/projects/sakiot-monorepo/FBI-agent/releases/%i/service.env
ExecStart=/home/tulipan/projects/sakiot-monorepo/FBI-agent/releases/%i/fbi_agent
TimeoutStopSec=infinity

[Install]
WantedBy=default.target
