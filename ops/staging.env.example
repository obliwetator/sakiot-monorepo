# Staging runtime profile. Same VPS as production, shared `sakiot` user, but a
# fully separate instance: own DB, ports, dirs, systemd units, data, and the
# DEBUG Discord bot. Installed to /etc/sakiot/staging.env.

SAKIOT_REPOSITORY_URL=https://github.com/OWNER/REPOSITORY.git
SAKIOT_ENV_FILE=/etc/sakiot/staging.env

# Separate filesystem layout so staging never touches production state.
SAKIOT_DATA_DIR=/var/lib/sakiot-staging/data
SAKIOT_DEPLOY_STATE_DIR=/var/lib/sakiot-staging/deploy
SAKIOT_RELEASE_ROOT=/srv/sakiot-staging/releases
SAKIOT_CURRENT_ROOT=/srv/sakiot-staging/current
SAKIOT_CACHE_DIR=/var/cache/sakiot-staging
SAKIOT_FRONTEND_ROOT=/var/www/staging.patrykstyla.com

# Staging listens on 8901; production is 8900.
SAKIOT_WEB_HEALTH_URL=http://127.0.0.1:8901/healthz
SAKIOT_WEB_REGISTRY_URL=http://127.0.0.1:8901/internal/fbi-agent/grpc-endpoints

# Staging systemd unit names. The deploy engine defaults to the production names
# when these are unset, so they must be present here.
SAKIOT_WEB_UNIT=sakiot-staging-web.service
SAKIOT_BOT_UNIT_PREFIX=sakiot-staging-fbi-agent@

SAKIOT_SYSTEMCTL_USE_SUDO=1
SAKIOT_KEEP_RELEASES=5
SAKIOT_ROLLBACK_FORCE_REBUILD=0

# The staging database is disposable, so skip the encrypted pre-migrate backup
# (migrations still run). Set to 0 and configure AGE_RECIPIENT below if you want
# staging backups.
SAKIOT_SKIP_DB_BACKUP=1

# Staging database, separate from production sakiot_rouvas. Create it once with
# `createdb sakiot_staging`; the first staging deploy runs its migrations.
DATABASE_URL=postgres://sakiot:replace_me@127.0.0.1/sakiot_staging
# Shared test master is safe because SQLx creates a fresh temporary database
# for every test. Never point this at staging or production.
SAKIOT_TEST_DATABASE_URL=postgres://sakiot_test:replace_me@127.0.0.1/sakiot_test
BACKUP_DATABASE_URL=postgres://sakiot:replace_me@127.0.0.1/sakiot_staging
BACKUP_DIR=/var/lib/sakiot-staging/backups
AGE_RECIPIENT=age1replace_me

SAKIOT_DATA_DIR=/var/lib/sakiot-staging/data

# Staging runs the DEBUG Discord bot. The bot binary is built with
# `cargo build --release`, which reads the *_RELEASE* slots (see
# FBI-agent/src/config.rs), so the debug bot's credentials go here.
DISCORD_TOKEN_RELEASE=replace_with_debug_bot_token
APPLICATION_ID_RELEASE=000000000000000000
DISCORD_CLIENT_ID=replace_me
DISCORD_CLIENT_SECRET=replace_me
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
# Used only to expire pre-__Host legacy cookies. Current auth cookies are
# host-only and deliberately omit Domain.
COOKIE_DOMAIN=debug.patrykstyla.com
DISCORD_REDIRECT_URI=https://debug.patrykstyla.com/api/discord_login
CORS_ALLOWED_ORIGIN=https://debug.patrykstyla.com
# Exact-match allowlist for the OAuth login popup opener origin. Defaults to
# CORS_ALLOWED_ORIGIN when unset. Exact opener origins are also trusted CORS
# origins so the debug Vite frontend can call the staging API with credentials.
OAUTH_ALLOWED_OPENER_ORIGINS=https://debug.patrykstyla.com,https://staging.patrykstyla.com
FBI_AGENT_REGISTRY_SECRET=replace_me
HOST=127.0.0.1
PORT=8901

# Dev login on staging (skip Discord OAuth). Backend requires BOTH:
DEV_ACCOUNT_ID=000000000000000000
DEV_LOGIN_SECRET=replace_with_a_strong_secret
# Optional: bake the secret into the bundle to skip the prompt. This makes it
# readable in the public client JS; leave unset to be prompted on click instead.
# VITE_DEV_LOGIN_SECRET=

# Embedded into the staging frontend bundle at build time (Vite reads VITE_*
# from the environment). Points the staging UI at the staging API origin.
VITE_API_URL=https://debug.patrykstyla.com/api/
