#!/usr/bin/env bash
set -euo pipefail

# Entry point for the SSH forced command. Dispatches to the Rust deploy
# engine (ops/sakiot-deploy), installed out-of-band at bin/ by
# install-production.sh / update-deploy-engine.sh — never built from the
# release worktree, so a broken commit cannot brick deploys.

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
binary="${script_dir}/bin/sakiot-deploy"

[[ -x "${binary}" ]] || {
  echo "error: ${binary} is not installed (run ops/update-deploy-engine.sh)" >&2
  exit 1
}

exec "${binary}" "$@"
