SAKIOT_REPOSITORY_URL=https://github.com/OWNER/REPOSITORY.git
SAKIOT_ENV_FILE=/etc/sakiot/production.env
SAKIOT_DATA_DIR=/var/lib/sakiot/data
SAKIOT_DEPLOY_STATE_DIR=/var/lib/sakiot/deploy
SAKIOT_RELEASE_ROOT=/srv/sakiot/releases
SAKIOT_CURRENT_ROOT=/srv/sakiot/current
SAKIOT_CACHE_DIR=/var/cache/sakiot
SAKIOT_FRONTEND_ROOT=/var/www/patrykstyla.com
SAKIOT_WEB_HEALTH_URL=http://127.0.0.1:8900/healthz
SAKIOT_WEB_REGISTRY_URL=http://127.0.0.1:8900/internal/fbi-agent/grpc-endpoints
SAKIOT_SYSTEMCTL_USE_SUDO=1

# Number of newest release directories kept under /srv/sakiot/releases. Older,
# unused releases are pruned after each successful deploy. In-use releases
# (current web, current bot, or any draining bot) are never pruned.
SAKIOT_KEEP_RELEASES=5

# Set to 1 to make rollback rebuild every component from source instead of
# reusing the binaries/dist already built for the target commit.
SAKIOT_ROLLBACK_FORCE_REBUILD=0

# Set to 1 to apply migrations without the encrypted pre-migrate backup. Keep 0
# in production so every schema change has an immediate restore point.
SAKIOT_SKIP_DB_BACKUP=0

# Optional one-time handoff from legacy tulipan user services. These are
# ignored after production deployment state exists.
SAKIOT_LEGACY_BOT_UNIT=
SAKIOT_LEGACY_BOT_GRPC=
SAKIOT_LEGACY_WEB_ENABLED=0

DATABASE_URL=postgres://sakiot:replace_me@127.0.0.1/sakiot_rouvas
BACKUP_DATABASE_URL=postgres://sakiot:replace_me@127.0.0.1/sakiot_rouvas
BACKUP_DIR=/var/lib/sakiot/backups
AGE_RECIPIENT=age1replace_me
AGE_KEY_FILE=/etc/sakiot/age-key.txt

SAKIOT_DATA_DIR=/var/lib/sakiot/data
DISCORD_TOKEN_RELEASE=replace_me
APPLICATION_ID_RELEASE=000000000000000000
DISCORD_CLIENT_ID=replace_me
DISCORD_CLIENT_SECRET=replace_me
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
COOKIE_DOMAIN=example.com
DISCORD_REDIRECT_URI=https://example.com/api/discord_login
CORS_ALLOWED_ORIGIN=https://example.com
FBI_AGENT_REGISTRY_SECRET=replace_me
HOST=127.0.0.1
PORT=8900
