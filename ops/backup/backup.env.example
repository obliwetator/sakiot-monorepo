# Copy to `backup.env` (gitignored) and fill in. Sourced by every script here.

# --- Connection --------------------------------------------------------------
# Used by pg_dump (single, fixed db).
DATABASE_URL="postgres://postgres:CHANGEME@localhost/sakiot_rouvas"

# Used by restore / restore-test (db name varies, so libpq env vars instead).
# Exported so child binaries (pg_restore/createdb/dropdb/psql) inherit them.
export PGHOST="localhost"
export PGPORT="5432"
export PGUSER="postgres"
export PGPASSWORD="CHANGEME"

# --- Storage -----------------------------------------------------------------
# LOCAL ONLY. Put this on a SEPARATE disk/mount if you can — local-only means a
# disk failure loses the db AND its backups. See README "Future: offsite".
BACKUP_DIR="/var/backups/sakiot"

# --- Encryption (age) --------------------------------------------------------
# Make a keypair once:  age-keygen -o /etc/sakiot/age-key.txt
# The command prints the PUBLIC key ("Public key: age1...") -> AGE_RECIPIENT.
# The FILE holds the PRIVATE key -> AGE_KEY_FILE (needed only to restore).
# Store AGE_KEY_FILE OFF THIS HOST too: lost key = unrecoverable backups.
AGE_RECIPIENT="age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxq9xxxxx"
AGE_KEY_FILE="/etc/sakiot/age-key.txt"

# --- Retention (days) --------------------------------------------------------
HOURLY_RETENTION_DAYS=7
NIGHTLY_RETENTION_DAYS=90
PREMIGRATE_RETENTION_DAYS=90

# --- Optional dead-man monitoring -------------------------------------------
# A URL pinged on success; if your monitor stops hearing the ping it alerts.
# HEALTHCHECK_URL="https://hc-ping.com/your-uuid-backup"
# HEALTHCHECK_URL_RESTORE="https://hc-ping.com/your-uuid-restore-test"
