#!/bin/bash
set -euo pipefail

bot_unit_pattern='^sakiot(-staging)?-fbi-agent@[A-Za-z0-9._-]+\.service$'
web_unit_pattern='^sakiot(-staging)?-web\.service$'
legacy_bot_unit_pattern='^fbi-agent@[A-Za-z0-9._-]+\.service$'
legacy_machine='tulipan@.host'

case "${1:-}" in
  start|enable|disable)
    [[ "$#" -eq 2 && "$2" =~ ${bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl "$1" "$2"
    ;;
  stop)
    [[ "$#" -eq 2 ]] || exit 2
    [[ "$2" =~ ${bot_unit_pattern} || "$2" =~ ${web_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl stop "$2"
    ;;
  is-active)
    [[ "$#" -eq 3 && "$2" == "--quiet" && "$3" =~ ${bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl is-active --quiet "$3"
    ;;
  restart)
    [[ "$#" -eq 2 && "$2" =~ ${web_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl restart "$2"
    ;;
  enable-web)
    [[ "$#" -eq 2 && "$2" =~ ${web_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl enable "$2"
    ;;
  legacy-web-is-active)
    [[ "$#" -eq 1 ]] || exit 2
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      is-active --quiet web_server.service
    ;;
  legacy-web-stop-disable)
    [[ "$#" -eq 1 ]] || exit 2
    /usr/bin/systemctl --user --machine="${legacy_machine}" \
      stop web_server.service
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      disable web_server.service
    ;;
  legacy-web-start-enable)
    [[ "$#" -eq 1 ]] || exit 2
    /usr/bin/systemctl --user --machine="${legacy_machine}" \
      enable web_server.service
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      start web_server.service
    ;;
  legacy-bot-is-active)
    [[ "$#" -eq 2 && "$2" =~ ${legacy_bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      is-active --quiet "$2"
    ;;
  legacy-bot-disable)
    [[ "$#" -eq 2 && "$2" =~ ${legacy_bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      disable "$2"
    ;;
  legacy-bot-enable)
    [[ "$#" -eq 2 && "$2" =~ ${legacy_bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      enable "$2"
    ;;
  legacy-bot-restart)
    [[ "$#" -eq 2 && "$2" =~ ${legacy_bot_unit_pattern} ]] || exit 2
    exec /usr/bin/systemctl --user --machine="${legacy_machine}" \
      restart "$2"
    ;;
  *)
    exit 2
    ;;
esac
